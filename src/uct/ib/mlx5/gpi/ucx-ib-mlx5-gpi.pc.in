libdir = @libdir@/ucx

Name: @PACKAGE@-ib-mlx5-gpi
Description: Unified Communication X Library GPU Push Interface module
Version: @VERSION@
Cflags:
Libs:
Libs.private: -L${libdir} -luct_ib_mlx5_gpi -Wl,--undefined=uct_rc_gpi_init @IBVERBS_LDFLAGS@ @CUDA_LDFLAGS@
Requires.private: @PACKAGE@-mlx5 @PACKAGE@-cuda

